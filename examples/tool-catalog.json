      "command_template": "python fengshui-master/scripts/create_brief.py \"<question>\" --pretty",
      "inputs": [
        {"name": "question", "type": "string", "required": true, "description": "User question or consultation goal."},
        {"name": "floorplan", "type": "path", "required": false, "description": "Optional structured floor-plan JSON path."},
        {"name": "pretty", "type": "boolean", "required": false, "description": "Print indented JSON."}
      ],
      "output_format": "json",
      "risk_level": "medium",
      "required_guardrails": ["preserve brief guardrails in final answer"]
