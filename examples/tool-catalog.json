{
  "name": "fengshui-master-tool-catalog",
  "version": "1.0.0",
  "purpose": "Machine-readable script metadata for agent tool registration, CLI wrappers, function calling adapters, and integration smoke tests.",
  "tools": [
    {
      "name": "domain_router",
      "path": "fengshui-master/scripts/domain_router.py",
      "category": "routing",
      "description": "Route a user question to FengShui Master domains, references, guardrails, and symbolic lenses.",
      "command_template": "python fengshui-master/scripts/domain_router.py \"<question>\" --pretty",
      "inputs": [
        {"name": "question", "type": "string", "required": true, "description": "User question or short task description."},
        {"name": "pretty", "type": "boolean", "required": false, "description": "Print indented JSON."}
      ],
      "output_format": "json",
      "risk_level": "low",
      "required_guardrails": ["route before answering substantial requests"]
    },
    {
      "name": "create_brief",
      "path": "fengshui-master/scripts/create_brief.py",
