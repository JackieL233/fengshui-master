      "inputs": [
        {"name": "question", "type": "string", "required": true, "description": "User question or consultation goal."},
        {"name": "floorplan", "type": "path", "required": false, "description": "Optional structured floor-plan JSON path."},
        {"name": "output", "type": "path", "required": false, "description": "Optional output Markdown path."}
      ],
      "output_format": "markdown",
      "risk_level": "medium",
      "required_guardrails": ["treat report as a scaffold not final authority"]
