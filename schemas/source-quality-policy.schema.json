{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/JackieL233/fengshui-master/schemas/source-quality-policy.schema.json",
  "title": "FengShui Master Source Quality Policy",
  "type": "object",
  "required": [
    "name",
    "version",
    "purpose",
    "source_tiers",
    "claim_policies",
    "citation_rules",
    "red_lines"
  ],
  "properties": {
    "name": {
      "type": "string",
      "const": "fengshui-master-source-quality-policy"
    },
    "version": { "type": "string" },
    "purpose": { "type": "string" },
    "source_tiers": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/sourceTier" }
    },
    "claim_policies": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/claimPolicy" }
    },
    "citation_rules": { "$ref": "#/$defs/stringList" },
    "red_lines": { "$ref": "#/$defs/stringList" }
  },
  "additionalProperties": false,
  "$defs": {
    "sourceTier": {
      "type": "object",
      "required": ["id", "label", "best_for", "acceptable_evidence", "output_posture", "limitations"],
      "properties": {
        "id": { "type": "string" },
        "label": { "type": "string" },
        "best_for": { "$ref": "#/$defs/stringList" },
        "acceptable_evidence": { "$ref": "#/$defs/stringList" },
        "output_posture": { "type": "string" },
        "limitations": { "$ref": "#/$defs/stringList" }
      },
      "additionalProperties": false
    },
    "claimPolicy": {
      "type": "object",
      "required": [
        "claim_type",
        "support_level",
        "minimum_sources",
        "required_labels",
        "required_checks",
        "red_lines"
      ],
      "properties": {
        "claim_type": { "type": "string" },
        "support_level": {
          "type": "string",
          "enum": [
            "supported",
            "cautious",
            "adapter_only",
            "high_stakes_symbolic_only",
            "out_of_scope_without_external_source"
          ]
        },
        "minimum_sources": { "$ref": "#/$defs/stringList" },
        "required_labels": { "$ref": "#/$defs/stringList" },
        "required_checks": { "$ref": "#/$defs/stringList" },
        "red_lines": { "$ref": "#/$defs/stringList" }
      },
      "additionalProperties": false
    },
    "stringList": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1,
      "uniqueItems": true
    }
  }
}
