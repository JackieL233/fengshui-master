{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/JackieL233/fengshui-master/schemas/tool-catalog.schema.json",
  "title": "FengShui Master Tool Catalog",
  "type": "object",
  "required": ["name", "version", "purpose", "tools"],
  "properties": {
    "name": {
      "type": "string",
      "const": "fengshui-master-tool-catalog"
    },
    "version": { "type": "string" },
    "purpose": { "type": "string" },
    "tools": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/toolEntry" }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "toolEntry": {
      "type": "object",
      "required": [
        "name",
        "path",
        "category",
        "description",
        "command_template",
        "inputs",
        "output_format",
        "risk_level",
        "required_guardrails"
      ],
      "properties": {
        "name": { "type": "string" },
        "path": { "type": "string" },
        "category": {
          "type": "string",
          "enum": ["routing", "briefing", "reporting", "floorplan", "calculation", "timing"]
        },
        "description": { "type": "string" },
        "command_template": { "type": "string" },
        "inputs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/toolInput" }
        },
        "output_format": {
          "type": "string",
          "enum": ["json", "markdown"]
        },
        "risk_level": {
          "type": "string",
          "enum": ["low", "medium", "high", "critical"]
        },
        "required_guardrails": { "$ref": "#/$defs/stringList" }
      },
      "additionalProperties": false
    },
    "toolInput": {
      "type": "object",
      "required": ["name", "type", "required", "description"],
      "properties": {
        "name": { "type": "string" },
        "type": {
          "type": "string",
          "enum": ["string", "integer", "number", "boolean", "path", "date"]
        },
        "required": { "type": "boolean" },
        "description": { "type": "string" }
      },
      "additionalProperties": false
    },
    "stringList": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1,
      "uniqueItems": true
    }
  }
}
