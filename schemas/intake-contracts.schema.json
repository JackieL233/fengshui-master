{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/JackieL233/fengshui-master/schemas/intake-contracts.schema.json",
  "title": "FengShui Master Intake Contracts",
  "type": "object",
  "required": ["name", "version", "purpose", "domains"],
  "properties": {
    "name": {
      "type": "string",
      "const": "fengshui-master-intake-contracts"
    },
    "version": { "type": "string" },
    "purpose": { "type": "string" },
    "domains": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/domainContract" }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "domainContract": {
      "type": "object",
      "required": [
        "domain",
        "summary",
        "required_inputs",
        "optional_inputs",
        "ask_first_if_missing",
        "blocking_missing_inputs",
        "assumption_allowed_inputs",
        "boundary_disclosures",
        "red_lines",
        "routing_hints"
      ],
      "properties": {
        "domain": { "type": "string" },
        "summary": { "type": "string" },
        "required_inputs": { "$ref": "#/$defs/stringList" },
        "optional_inputs": { "$ref": "#/$defs/stringList" },
        "ask_first_if_missing": { "$ref": "#/$defs/stringList" },
        "blocking_missing_inputs": { "$ref": "#/$defs/stringList" },
        "assumption_allowed_inputs": { "$ref": "#/$defs/stringList" },
        "boundary_disclosures": { "$ref": "#/$defs/stringList" },
        "red_lines": { "$ref": "#/$defs/stringList" },
        "routing_hints": { "$ref": "#/$defs/stringList" }
      },
      "additionalProperties": false
    },
    "stringList": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1,
      "uniqueItems": true
    }
  }
}
