{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/JackieL233/fengshui-master/schemas/external-calculation-contracts.schema.json",
  "title": "FengShui Master External Calculation Contracts",
  "type": "object",
  "required": ["name", "version", "purpose", "systems"],
  "properties": {
    "name": {
      "type": "string",
      "const": "fengshui-master-external-calculation-contracts"
    },
    "version": { "type": "string" },
    "purpose": { "type": "string" },
    "systems": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/system" }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "system": {
      "type": "object",
      "required": [
        "id",
        "title",
        "status",
        "required_inputs",
        "required_source_proof",
        "required_outputs",
        "allowed_use",
        "red_lines",
        "fallback_without_engine"
      ],
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "status": {
          "type": "string",
          "enum": ["external_required", "external_or_user_supplied_source_required"]
        },
        "required_inputs": { "$ref": "#/$defs/stringList" },
        "required_source_proof": { "$ref": "#/$defs/stringList" },
        "required_outputs": { "$ref": "#/$defs/stringList" },
        "allowed_use": { "$ref": "#/$defs/stringList" },
        "red_lines": { "$ref": "#/$defs/stringList" },
        "fallback_without_engine": { "type": "string" }
      },
      "additionalProperties": false
    },
    "stringList": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1,
      "uniqueItems": true
    }
  }
}
