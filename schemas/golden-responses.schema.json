{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/JackieL233/fengshui-master/schemas/golden-responses.schema.json",
  "title": "FengShui Master Golden Responses",
  "type": "object",
  "required": ["name", "version", "purpose", "responses"],
  "properties": {
    "name": {
      "type": "string",
      "const": "fengshui-master-golden-responses"
    },
    "version": { "type": "string" },
    "purpose": { "type": "string" },
    "responses": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/response" }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "response": {
      "type": "object",
      "required": [
        "id",
        "domain",
        "prompt",
        "expected_references",
        "outline",
        "required_phrases",
        "forbidden_phrases",
        "quality_checks"
      ],
      "properties": {
        "id": { "type": "string" },
        "domain": { "type": "string" },
        "prompt": { "type": "string" },
        "expected_references": { "$ref": "#/$defs/stringList" },
        "outline": { "$ref": "#/$defs/stringList" },
        "required_phrases": { "$ref": "#/$defs/stringList" },
        "forbidden_phrases": { "$ref": "#/$defs/stringList" },
        "quality_checks": { "$ref": "#/$defs/stringList" }
      },
      "additionalProperties": false
    },
    "stringList": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1,
      "uniqueItems": true
    }
  }
}
