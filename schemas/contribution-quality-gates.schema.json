{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/JackieL233/fengshui-master/schemas/contribution-quality-gates.schema.json",
  "title": "FengShui Master Contribution Quality Gates",
  "type": "object",
  "required": ["name", "version", "purpose", "gates"],
  "properties": {
    "name": {
      "type": "string",
      "const": "fengshui-master-contribution-quality-gates"
    },
    "version": { "type": "string" },
    "purpose": { "type": "string" },
    "gates": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/gate" }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "gate": {
      "type": "object",
      "required": ["id", "applies_to", "required_artifacts", "required_checks", "required_validation", "red_lines"],
      "properties": {
        "id": { "type": "string" },
        "applies_to": { "$ref": "#/$defs/stringList" },
        "required_artifacts": { "$ref": "#/$defs/stringList" },
        "required_checks": { "$ref": "#/$defs/stringList" },
        "required_validation": { "$ref": "#/$defs/stringList" },
        "red_lines": { "$ref": "#/$defs/stringList" }
      },
      "additionalProperties": false
    },
    "stringList": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1,
      "uniqueItems": true
    }
  }
}
