{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/JackieL233/fengshui-master/schemas/runtime-integration-profiles.schema.json",
  "title": "FengShui Master Runtime Integration Profiles",
  "type": "object",
  "required": ["name", "version", "purpose", "profiles"],
  "properties": {
    "name": {
      "type": "string",
      "const": "fengshui-master-runtime-integration-profiles"
    },
    "version": { "type": "string" },
    "purpose": { "type": "string" },
    "profiles": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/profile" }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "profile": {
      "type": "object",
      "required": [
        "id",
        "runtime",
        "required_assets",
        "required_steps",
        "tooling",
        "validation_commands",
        "red_lines"
      ],
      "properties": {
        "id": { "type": "string" },
        "runtime": { "type": "string" },
        "required_assets": { "$ref": "#/$defs/stringList" },
        "required_steps": { "$ref": "#/$defs/stringList" },
        "tooling": { "$ref": "#/$defs/stringList" },
        "validation_commands": { "$ref": "#/$defs/stringList" },
        "red_lines": { "$ref": "#/$defs/stringList" }
      },
      "additionalProperties": false
    },
    "stringList": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1,
      "uniqueItems": true
    }
  }
}
