{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/JackieL233/fengshui-master/schemas/reference-catalog.schema.json",
  "title": "FengShui Master Reference Catalog",
  "type": "object",
  "required": ["name", "version", "purpose", "references"],
  "properties": {
    "name": {
      "type": "string",
      "const": "fengshui-master-reference-catalog"
    },
    "version": { "type": "string" },
    "purpose": { "type": "string" },
    "references": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/referenceEntry" }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "referenceEntry": {
      "type": "object",
      "required": [
        "path",
        "title",
        "primary_domain",
        "risk_level",
        "tags",
        "required_guardrails"
      ],
      "properties": {
        "path": { "type": "string" },
        "title": { "type": "string" },
        "primary_domain": { "type": "string" },
        "risk_level": {
          "type": "string",
          "enum": ["low", "medium", "high", "critical"]
        },
        "tags": { "$ref": "#/$defs/stringList" },
        "required_guardrails": { "$ref": "#/$defs/stringList" }
      },
      "additionalProperties": false
    },
    "stringList": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1,
      "uniqueItems": true
    }
  }
}
