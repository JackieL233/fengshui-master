{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/JackieL233/fengshui-master/schemas/capability-matrix.schema.json",
  "title": "FengShui Master Capability Matrix",
  "type": "object",
  "required": ["name", "version", "purpose", "statuses", "capabilities"],
  "properties": {
    "name": {
      "type": "string",
      "const": "fengshui-master-capability-matrix"
    },
    "version": { "type": "string" },
    "purpose": { "type": "string" },
    "statuses": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["fully_covered", "partially_covered", "not_covered"]
      },
      "minItems": 3,
      "uniqueItems": true
    },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/capability" }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "capability": {
      "type": "object",
      "required": [
        "id",
        "title",
        "status",
        "domains",
        "supported_questions",
        "required_inputs",
        "references",
        "optional_tools",
        "guardrails",
        "limitations",
        "adaptation_notes"
      ],
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "status": {
          "type": "string",
          "enum": ["fully_covered", "partially_covered", "not_covered"]
        },
        "domains": { "$ref": "#/$defs/stringList" },
        "supported_questions": { "$ref": "#/$defs/stringList" },
        "required_inputs": { "$ref": "#/$defs/stringList" },
        "references": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "optional_tools": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "guardrails": { "$ref": "#/$defs/stringList" },
        "limitations": { "$ref": "#/$defs/stringList" },
        "adaptation_notes": { "$ref": "#/$defs/stringList" }
      },
      "additionalProperties": false
    },
    "stringList": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1,
      "uniqueItems": true
    }
  }
}
